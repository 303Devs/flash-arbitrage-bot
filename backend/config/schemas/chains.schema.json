{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chain Configuration",
  "type": "object",
  "patternProperties": {
    "^[0-9]+$": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "rpcUrls": {
          "type": "object",
          "properties": {
            "primary": { "type": "string", "format": "uri" },
            "fallback": { "type": "string", "format": "uri" },
            "websocket": { "type": "string", "format": "uri" }
          },
          "required": ["primary"]
        },
        "nativeCurrency": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "symbol": { "type": "string" },
            "decimals": { "type": "number", "const": 18 }
          },
          "required": ["name", "symbol", "decimals"]
        },
        "gasSettings": {
          "type": "object",
          "properties": {
            "maxGasPrice": { "type": "string" },
            "gasMultiplier": { "type": "number", "minimum": 1 },
            "profitThreshold": { "type": "string" }
          },
          "required": ["maxGasPrice", "gasMultiplier", "profitThreshold"]
        }
      },
      "required": ["name", "rpcUrls", "nativeCurrency", "gasSettings"]
    }
  }
}
