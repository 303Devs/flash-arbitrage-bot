{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Token Configuration",
  "type": "object",
  "patternProperties": {
    "^[0-9]+$": {
      "type": "object",
      "patternProperties": {
        "^0x[a-fA-F0-9]{40}$": {
          "type": "object",
          "properties": {
            "symbol": { "type": "string" },
            "name": { "type": "string" },
            "decimals": { "type": "number", "minimum": 0, "maximum": 18 },
            "priority": { "type": "number", "minimum": 1, "maximum": 20 }
          },
          "required": ["symbol", "name", "decimals", "priority"]
        }
      }
    }
  }
}
