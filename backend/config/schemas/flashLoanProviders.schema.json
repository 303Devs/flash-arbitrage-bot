{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flash Loan Provider Configuration",
  "type": "object",
  "patternProperties": {
    "^[0-9]+$": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_-]+$": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "address": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
            "fee": { "type": "number", "minimum": 0, "maximum": 1 },
            "maxLiquidity": {
              "type": "object",
              "patternProperties": {
                "^0x[a-fA-F0-9]{40}$": { "type": "string" }
              }
            },
            "type": { "enum": ["aave", "balancer", "uniswap-v3"] }
          },
          "required": ["name", "address", "fee", "type"]
        }
      }
    }
  }
}
