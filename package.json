{
  "name": "mev-bot-ultimate",
  "version": "1.0.0",
  "description": "Ultimate MEV extraction system - Direct node architecture for $10k+ daily profits",
  "main": "dist/src/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/src/main.js",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist coverage artifacts cache",
    "compile": "hardhat compile",
    "deploy:arbitrum": "hardhat run scripts/deploy.cjs --network arbitrum",
    "deploy:polygon": "hardhat run scripts/deploy.cjs --network polygon",
    "deploy:base": "hardhat run scripts/deploy.cjs --network base",
    "deploy:arbitrumSepolia": "hardhat run scripts/deploy.cjs --network arbitrumSepolia",
    "deploy:polygonAmoy": "hardhat run scripts/deploy.cjs --network polygonAmoy",
    "deploy:baseSepolia": "hardhat run scripts/deploy.cjs --network baseSepolia"
  },
  "keywords": [
    "mev",
    "sandwich",
    "flash-loan",
    "defi",
    "arbitrage",
    "jit-liquidity",
    "liquidation"
  ],
  "author": "303Devs",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "chalk": "^5.4.1",
    "dotenv": "^17.2.0",
    "ethers": "^6.15.0",
    "viem": "^2.33.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.9",
    "@nomicfoundation/hardhat-verify": "^2.0.15",
    "@types/node": "^24.0.15",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "hardhat": "^2.24.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
