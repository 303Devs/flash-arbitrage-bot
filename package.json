{
  "name": "arbitration-flash-bot",
  "version": "1.0.0",
  "description": "A no capital, flash loan arbitration bot",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec ts-node --esm backend/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint backend/**/*.ts",
    "format": "prettier --write backend/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "arbitrage",
    "flash-loan",
    "defi",
    "bot"
  ],
  "author": "303Devs",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.0",
    "drizzle-orm": "^0.44.3",
    "ethers": "^6.15.0",
    "ioredis": "^5.6.1",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "prom-client": "^15.1.3",
    "viem": "^2.33.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@eslint/json": "^0.13.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@types/chai": "^4.3.0",
    "@types/node": "^24.0.15",
    "@types/pg": "^8.6.6",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "chai": "^4.5.0",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "hardhat": "^2.26.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^3.2.4"
  }
}
