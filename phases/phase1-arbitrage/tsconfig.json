{
  "compilerOptions": {
    "target":                  "ES2022",
    "module":                  "NodeNext",
    "moduleResolution":        "NodeNext",
    "lib":                     ["ES2022"],
    "esModuleInterop":         true,
    "allowSyntheticDefaultImports": true,
    "strict":                  true,
    "outDir":                  "./dist",
    "rootDir":                 "./src",
    "skipLibCheck":            true,
    "declaration":             true,
    "sourceMap":               true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
