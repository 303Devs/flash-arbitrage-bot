# =====================================================
# PHASE 1 ARBITRAGE BOT - Environment Configuration
# =====================================================
# Copy to .env and fill in your values
# cp .env.example .env

# === WALLET ===
PRIVATE_KEY=0x_your_private_key_here

# === RPC PROVIDERS (WebSocket - primary) ===
# Get from: https://dashboard.quicknode.com or https://dashboard.alchemy.com
QUICKNODE_ARBITRUM_WSS=wss://your-arbitrum-endpoint.quiknode.pro/key/
QUICKNODE_POLYGON_WSS=wss://your-polygon-endpoint.quiknode.pro/key/
QUICKNODE_BASE_WSS=wss://your-base-endpoint.quiknode.pro/key/

ALCHEMY_ARBITRUM_WSS=wss://arb-mainnet.g.alchemy.com/v2/your_key
ALCHEMY_POLYGON_WSS=wss://polygon-mainnet.g.alchemy.com/v2/your_key
ALCHEMY_BASE_WSS=wss://base-mainnet.g.alchemy.com/v2/your_key

# === RPC PROVIDERS (HTTP - fallback + hardhat) ===
QUICKNODE_ARBITRUM_HTTP=https://your-arbitrum-endpoint.quiknode.pro/key/
QUICKNODE_POLYGON_HTTP=https://your-polygon-endpoint.quiknode.pro/key/
QUICKNODE_BASE_HTTP=https://your-base-endpoint.quiknode.pro/key/

ALCHEMY_ARBITRUM_HTTP=https://arb-mainnet.g.alchemy.com/v2/your_key
ALCHEMY_POLYGON_HTTP=https://polygon-mainnet.g.alchemy.com/v2/your_key
ALCHEMY_BASE_HTTP=https://base-mainnet.g.alchemy.com/v2/your_key
ALCHEMY_API_KEY=your_alchemy_api_key

# === DEPLOYED CONTRACT ADDRESSES ===
# Set after running: pnpm deploy:arbitrum (or polygon/base)
ARBITRAGE_CONTRACT_ARBITRUM=
ARBITRAGE_CONTRACT_POLYGON=
ARBITRAGE_CONTRACT_BASE=

# === PROFIT THRESHOLDS (USD) ===
MIN_PROFIT_USD_ARBITRUM=3
MIN_PROFIT_USD_POLYGON=1
MIN_PROFIT_USD_BASE=2

# === GAS LIMITS (gwei) ===
MAX_GAS_PRICE_GWEI_ARBITRUM=5
MAX_GAS_PRICE_GWEI_POLYGON=100
MAX_GAS_PRICE_GWEI_BASE=2

# === CHAINS TO ENABLE (comma-separated) ===
ENABLED_CHAINS=arbitrum,polygon,base

# === LOGGING ===
LOG_LEVEL=info
NODE_ENV=development

# === OPTIONAL: Redis (for reliable nonce management) ===
# Redis prevents "replacement fee too low" errors on high-frequency trading
# REDIS_URL=redis://localhost:6379

# === OPTIONAL: Monitoring ===
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
